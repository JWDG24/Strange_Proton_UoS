#!/usr/bin/env python3

# ============================================================
# plot_csv_E2E1.py
#
# Purpose:
#   Read all correction-factor CSV files from INPUT_DIR,
#   convert each one into a ROOT TH1D,
#   draw:
#     - E2 filled band for the correction factor uncertainty
#     - E1 points + vertical error bars + bin-width bars
#     - uncertainty curves on a right-hand y-axis
#
# Run with:
#   python3 plot_csv_E2E1.py
#
# Requirements:
#   - PyROOT installed
#   - CSV files contain columns:
#       bin_low_edge
#       bin_up_edge
#       correction_factor
#       stat_unc
#       scale_unc
#       pdf_unc
#       shower_unc
#       model_unc
#       total_unc
#
# Output:
#   For each CSV file:
#     - one PDF plot
#     - one PNG plot
#
# Notes:
#   - Processes all CSV files in INPUT_DIR
#   - Keeps the same output name suffix as before: _E2E1
# ============================================================

import os
import csv
from array import array

import ROOT

# ------------------------------------------------------------
# ROOT settings
# ------------------------------------------------------------
ROOT.gROOT.SetBatch(True)
ROOT.TH1.AddDirectory(False)
ROOT.gStyle.SetOptStat(0)

# Make horizontal error bars span the full bin width for E1
ROOT.gStyle.SetErrorX(0.5)

# ------------------------------------------------------------
# Input / output directories
# ------------------------------------------------------------
INPUT_DIR = "/mnt/c/Users/dugar/wcharm_analysis/final_work/build_corrections.py_CSV"
OUTPUT_DIR = "/mnt/c/Users/dugar/wcharm_analysis/final_work/plot_csv_E2E1_Output"

os.makedirs(OUTPUT_DIR, exist_ok=True)

# ------------------------------------------------------------
# Plot settings
# ------------------------------------------------------------
USE_SMART_X_TITLES = True
SAVE_PDF = True
SAVE_PNG = True

# CSV columns
CORR_COLUMN = "correction_factor"
TOTAL_COLUMN = "total_unc"
STAT_COLUMN = "stat_unc"
SCALE_COLUMN = "scale_unc"
PDF_COLUMN = "pdf_unc"
SHOWER_COLUMN = "shower_unc"
MODEL_COLUMN = "model_unc"

# ------------------------------------------------------------
# Helper functions
# ------------------------------------------------------------

def observable_to_x_title(observable_name: str) -> str:
    mapping = {
        "ptlepton": "p_{T}^{lep} [GeV]",
        "ptjet": "p_{T}^{jet} [GeV]",
        "etalepton": "|#eta^{lep}|",
        "etajet": "|#eta^{jet}|",
        "philepton": "#phi^{lep}",
        "phijet": "#phi^{jet}",
        "met_et": "E_{T}^{miss} [GeV]",
        "mtw": "m_{T}^{W} [GeV]",
    }
    return mapping.get(observable_name, observable_name)


def parse_csv_filename(filename: str):
    """
    Expected filename format:
      Pythia_minus_ptlepton.csv
      Herwig_plus_mtw.csv
    Returns:
      pair_label, observable
    """
    stem = os.path.splitext(os.path.basename(filename))[0]
    parts = stem.rsplit("_", 1)

    if len(parts) != 2:
        return stem, stem

    return parts[0], parts[1]


def make_pretty_title(pair_label: str, observable: str) -> str:
    pair_pretty = pair_label.replace("_", " ")
    return f"{pair_pretty}: {observable}"


def load_csv_data(csv_path: str):
    """
    Read all required columns from one CSV file.
    """
    low_edges = []
    up_edges = []

    corr_vals = []
    total_unc = []
    stat_unc = []
    scale_unc = []
    pdf_unc = []
    shower_unc = []
    model_unc = []

    with open(csv_path, "r", newline="") as f:
        reader = csv.DictReader(f)

        required_columns = [
            "bin_low_edge",
            "bin_up_edge",
            CORR_COLUMN,
            TOTAL_COLUMN,
            STAT_COLUMN,
            SCALE_COLUMN,
            PDF_COLUMN,
            SHOWER_COLUMN,
            MODEL_COLUMN,
        ]

        for col in required_columns:
            if col not in reader.fieldnames:
                raise RuntimeError(f"Missing required column '{col}' in {csv_path}")

        for row in reader:
            low_edges.append(float(row["bin_low_edge"]))
            up_edges.append(float(row["bin_up_edge"]))

            corr_vals.append(float(row[CORR_COLUMN]))
            total_unc.append(float(row[TOTAL_COLUMN]))
            stat_unc.append(float(row[STAT_COLUMN]))
            scale_unc.append(float(row[SCALE_COLUMN]))
            pdf_unc.append(float(row[PDF_COLUMN]))
            shower_unc.append(float(row[SHOWER_COLUMN]))
            model_unc.append(float(row[MODEL_COLUMN]))

    if not low_edges:
        raise RuntimeError(f"No data rows found in {csv_path}")

    return {
        "low_edges": low_edges,
        "up_edges": up_edges,
        "corr_vals": corr_vals,
        "total_unc": total_unc,
        "stat_unc": stat_unc,
        "scale_unc": scale_unc,
        "pdf_unc": pdf_unc,
        "shower_unc": shower_unc,
        "model_unc": model_unc,
    }


def make_hist_from_csv(csv_path: str, data_dict):
    """
    Build the correction-factor TH1D from CSV data.
    Bin content = correction factor
    Bin error   = total uncertainty
    """
    pair_label, observable = parse_csv_filename(csv_path)
    title = make_pretty_title(pair_label, observable)

    low_edges = data_dict["low_edges"]
    up_edges = data_dict["up_edges"]
    corr_vals = data_dict["corr_vals"]
    total_unc = data_dict["total_unc"]

    edges = [low_edges[0]] + up_edges
    edge_array = array("d", edges)

    hist_name = f"h_{pair_label}_{observable}"
    hist = ROOT.TH1D(hist_name, title, len(corr_vals), edge_array)
    hist.SetDirectory(0)

    for i, (y, e) in enumerate(zip(corr_vals, total_unc), start=1):
        hist.SetBinContent(i, y)
        hist.SetBinError(i, e)

    if USE_SMART_X_TITLES:
        hist.GetXaxis().SetTitle(observable_to_x_title(observable))
    else:
        hist.GetXaxis().SetTitle("Observable")

    hist.GetYaxis().SetTitle("Correction factor")
    hist.SetTitle(title)

    return hist, pair_label, observable


def make_band_hist(source_hist):
    """
    Clone for E2 filled band.
    """
    band = source_hist.Clone(source_hist.GetName() + "_band")
    band.SetDirectory(0)

    band.SetLineWidth(0)
    band.SetMarkerStyle(0)
    band.SetMarkerSize(0)
    band.SetFillStyle(1001)
    band.SetFillColorAlpha(ROOT.kBlue, 0.25)

    return band


def make_point_hist(source_hist):
    """
    Clone for E1 correction-factor points and bars.
    """
    points = source_hist.Clone(source_hist.GetName() + "_points")
    points.SetDirectory(0)

    points.SetLineColor(ROOT.kBlue + 2)
    points.SetLineWidth(2)
    points.SetMarkerColor(ROOT.kBlue + 2)
    points.SetMarkerStyle(20)
    points.SetMarkerSize(0.9)

    return points


def make_uncertainty_graph(low_edges, up_edges, values, name, color, marker_style, scale_factor):
    """
    Make a TGraph for one uncertainty source.
    The x values are bin centres.
    The y values are scaled so they can be drawn against the left axis.
    The true uncertainty scale is shown on the right axis.
    """
    n = len(values)
    x_vals = []
    y_vals = []

    for lo, hi, val in zip(low_edges, up_edges, values):
        x_centre = 0.5 * (lo + hi)
        x_vals.append(x_centre)
        y_vals.append(val * scale_factor)

    graph = ROOT.TGraph(n, array("d", x_vals), array("d", y_vals))
    graph.SetName(name)

    graph.SetLineColor(color)
    graph.SetMarkerColor(color)
    graph.SetLineWidth(2)
    graph.SetMarkerStyle(marker_style)
    graph.SetMarkerSize(0.9)

    return graph


def max_of_list(values):
    return max(values) if values else 0.0


def save_hist_plots(hist, csv_path: str, output_dir: str, data_dict):
    """
    Draw:
      - E2 band for total uncertainty on correction factor
      - E1 correction-factor points + bin-width bars
      - uncertainty graphs on a right y-axis
    """
    base = os.path.splitext(os.path.basename(csv_path))[0]

    low_edges = data_dict["low_edges"]
    up_edges = data_dict["up_edges"]

    total_unc = data_dict["total_unc"]
    stat_unc = data_dict["stat_unc"]
    scale_unc = data_dict["scale_unc"]
    pdf_unc = data_dict["pdf_unc"]
    shower_unc = data_dict["shower_unc"]
    model_unc = data_dict["model_unc"]

    # Determine left-axis range from correction factor band
    corr_max = max(
        hist.GetBinContent(i) + hist.GetBinError(i)
        for i in range(1, hist.GetNbinsX() + 1)
    )
    corr_min = min(
        hist.GetBinContent(i) - hist.GetBinError(i)
        for i in range(1, hist.GetNbinsX() + 1)
    )

    left_y_min = min(0.0, 0.9 * corr_min)
    left_y_max = 1.15 * corr_max if corr_max > 0 else 1.0

    # Determine right-axis range from all uncertainty columns
    unc_max = max(
        max_of_list(total_unc),
        max_of_list(stat_unc),
        max_of_list(scale_unc),
        max_of_list(pdf_unc),
        max_of_list(shower_unc),
        max_of_list(model_unc),
    )

    right_y_min = 0.0
    right_y_max = 1.20 * unc_max if unc_max > 0 else 1.0

    # Scale uncertainty values so they can be drawn on the left axis
    if right_y_max > 0:
        scale_factor = (left_y_max - left_y_min) / (right_y_max - right_y_min)
    else:
        scale_factor = 1.0

    canvas_name = f"c_{base}"
    canvas = ROOT.TCanvas(canvas_name, canvas_name, 1000, 750)
    canvas.SetRightMargin(0.12)

    # Correction-factor histograms
    band_hist = make_band_hist(hist)
    point_hist = make_point_hist(hist)

    band_hist.SetMinimum(left_y_min)
    band_hist.SetMaximum(left_y_max)

    # Draw correction factor first
    band_hist.Draw("E2")
    point_hist.Draw("E1 SAME")

    # Uncertainty graphs on right axis, scaled into left-axis coordinates
    g_total = make_uncertainty_graph(low_edges, up_edges, total_unc, "g_total", ROOT.kBlack, 24, scale_factor)
    g_stat = make_uncertainty_graph(low_edges, up_edges, stat_unc, "g_stat", ROOT.kRed + 1, 20, scale_factor)
    g_scale = make_uncertainty_graph(low_edges, up_edges, scale_unc, "g_scale", ROOT.kGreen + 2, 21, scale_factor)
    g_pdf = make_uncertainty_graph(low_edges, up_edges, pdf_unc, "g_pdf", ROOT.kMagenta + 1, 22, scale_factor)
    g_shower = make_uncertainty_graph(low_edges, up_edges, shower_unc, "g_shower", ROOT.kOrange + 7, 23, scale_factor)
    g_model = make_uncertainty_graph(low_edges, up_edges, model_unc, "g_model", ROOT.kCyan + 2, 33, scale_factor)

    # Draw uncertainty curves
    g_total.Draw("LP SAME")
    g_stat.Draw("LP SAME")
    g_scale.Draw("LP SAME")
    g_pdf.Draw("LP SAME")
    g_shower.Draw("LP SAME")
    g_model.Draw("LP SAME")

    # Right-hand axis for uncertainties
    x_max = hist.GetXaxis().GetXmax()
    axis_right = ROOT.TGaxis(
        x_max, left_y_min,
        x_max, left_y_max,
        right_y_min, right_y_max,
        510, "+L"
    )
    axis_right.SetTitle("Uncertainty")
    axis_right.SetTitleOffset(1.2)
    axis_right.Draw()

    # Legend
    legend = ROOT.TLegend(0.60, 0.58, 0.88, 0.88)
    legend.SetBorderSize(0)
    legend.SetFillStyle(0)

    legend.AddEntry(point_hist, "Correction factor", "lep")
    legend.AddEntry(g_total, "Total uncertainty", "lp")
    legend.AddEntry(g_stat, "Stat uncertainty", "lp")
    legend.AddEntry(g_scale, "Scale uncertainty", "lp")
    legend.AddEntry(g_pdf, "PDF uncertainty", "lp")
    legend.AddEntry(g_shower, "Shower uncertainty", "lp")
    legend.AddEntry(g_model, "Model uncertainty", "lp")

    legend.Draw()

    canvas.Update()

    saved_files = []

    # Keep the same output naming style as before
    if SAVE_PDF:
        pdf_path = os.path.join(output_dir, base + "_E2E1.pdf")
        canvas.SaveAs(pdf_path)
        saved_files.append(pdf_path)

    if SAVE_PNG:
        png_path = os.path.join(output_dir, base + "_E2E1.png")
        canvas.SaveAs(png_path)
        saved_files.append(png_path)

    return saved_files


def main():
    if not os.path.isdir(INPUT_DIR):
        raise RuntimeError(f"INPUT_DIR does not exist: {INPUT_DIR}")

    csv_files = sorted(
        os.path.join(INPUT_DIR, f)
        for f in os.listdir(INPUT_DIR)
        if f.endswith(".csv")
    )

    if not csv_files:
        raise RuntimeError(f"No CSV files found in INPUT_DIR: {INPUT_DIR}")

    print(f"Found {len(csv_files)} CSV files in:")
    print(f"  {INPUT_DIR}")
    print()

    saved_count = 0

    for csv_path in csv_files:
        try:
            data_dict = load_csv_data(csv_path)
            hist, pair_label, observable = make_hist_from_csv(csv_path, data_dict)

            saved_files = save_hist_plots(
                hist=hist,
                csv_path=csv_path,
                output_dir=OUTPUT_DIR,
                data_dict=data_dict
            )

            print(f"Plotted: {os.path.basename(csv_path)}")
            for path in saved_files:
                print(f"  -> {path}")

            saved_count += 1

        except Exception as e:
            print(f"Failed on {csv_path}")
            print(f"  Reason: {e}")

    print()
    print(f"Finished. Successfully plotted {saved_count} CSV files.")
    print("Output directory:")
    print(f"  {OUTPUT_DIR}")


if __name__ == "__main__":
    main()
